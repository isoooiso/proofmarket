# Solana devnet RPC
RPC_URL=https://api.devnet.solana.com

# Path to your devnet wallet keypair (solana-keygen new -o devnet-wallet.json)
WALLET_KEYPAIR=./devnet-wallet.json

# TxLINE devnet API base (note: -dev host for devnet)
TXLINE_API=https://txline-dev.txodds.com/api
TXLINE_AUTH=https://txline-dev.txodds.com

# Free-tier service level: 12 = real-time, 1 = 60s delayed (both free, no TxL)
SERVICE_LEVEL_ID=12
DURATION_WEEKS=4

# Filled in by `npm run subscribe` (the activation step prints these)
TXLINE_JWT=
TXLINE_API_TOKEN=

# Target stat to prove in the de-risk probe.
# Start by replicating the documented example, then switch to a real World Cup fixture.
FIXTURE_ID=17271370
SEQ=401
STAT_KEY=1
# STAT_KEY2=2   # set only for two-stat validation (e.g. home+away goals)
