# Solana devnet RPC (Helius recommended) — exposed to the browser bundle (safe for RPC URLs)
VITE_RPC_URL=https://api.devnet.solana.com

# Demo-safe mode: no RPC polling loops (default on)
VITE_DEMO_SAFE_MODE=true

# --- Local dev only (not used in Vercel production) ---
# TxLINE API token for the dev-server proxy (same as Vercel TXLINE_API_TOKEN).
# Set in repo root .env or app/.env; never prefix with VITE_.
# TXLINE_API_TOKEN=txoracle_api_...
